# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/elearning_db?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Cookie
COOKIE_SECRET=your-cookie-secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Zoom API (Feature: Pertemuan Virtual) — kosongkan untuk pakai mock meeting saat NODE_ENV=development.
# Isi 3 var ini untuk pakai Zoom API asli (Server-to-Server OAuth app).
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
