NODE_ENV=test
PORT=8000
API_PREFIX=/api

# MongoDB — dummy, jest tests mock repositories and never hit real DB
MONGODB_URI=mongodb://localhost:27017/e-learning-test

# JWT
JWT_SECRET=test-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-secret-change-in-production-min-32
JWT_REFRESH_EXPIRES_IN=30d

# Cookie
COOKIE_SECRET=test-cookie-secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Zoom API — kosong, tidak dipakai di unit test (zoom.client di-mock)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
